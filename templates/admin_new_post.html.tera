<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Create Post - Admin</title>
    {% include "tailwind" %}
</head>
<body class="bg-[#020617] text-gray-100 min-h-screen font-sans">
    <div class="max-w-6xl mx-auto px-4 py-8">
        <!-- Top Navigation Header -->
        <header class="flex items-center justify-between mb-8 pb-4 border-b border-slate-800">
            <div class="flex items-center gap-4">
                <a href="/admin/dashboard" class="text-xs font-mono text-slate-500 hover:text-indigo-400">&larr; back_to_dashboard</a>
                <h1 class="text-2xl font-bold font-heading text-indigo-200 select-none">$ create_new_post</h1>
            </div>
        </header>

        <!-- Entire page wrapped in a single form to submit all content together -->
        <form action="/admin/posts/new" method="POST" enctype="multipart/form-data">
            <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
                <!-- Left Side: Post Text Content (span 2) -->
                <div class="lg:col-span-2 space-y-6">
                    <main class="border border-slate-800 bg-slate-950/60 backdrop-blur-sm p-6 md:p-8 shadow-xl">
                        <h2 class="text-md font-mono text-indigo-300 mb-6">$ compose_post</h2>
                        
                        <div class="space-y-6">
                            <!-- Title Field -->
                            <div>
                                <label for="title" class="block text-xs font-mono text-slate-500 mb-1.5">$ post_title</label>
                                <input type="text" id="title" name="title" required placeholder="Enter post title..." class="w-full bg-slate-900 border border-slate-800 p-2.5 text-sm text-gray-100 focus:outline-none focus:border-indigo-500 transition-colors">
                            </div>

                            <!-- Content Field -->
                            <div>
                                <label for="content" class="block text-xs font-mono text-slate-500 mb-1.5">$ post_content (Markdown / HTML supported)</label>
                                <textarea id="content" name="content" rows="16" required placeholder="Write your post content here..." class="w-full bg-slate-900 border border-slate-800 p-2.5 text-sm font-mono text-gray-100 focus:outline-none focus:border-indigo-500 transition-colors resize-y"></textarea>
                            </div>

                            <!-- Draft Toggle Checkbox -->
                            <div class="flex items-center gap-2 pt-4 border-t border-slate-900">
                                <input type="checkbox" id="draft" name="draft" value="true" class="w-4 h-4 bg-slate-900 border border-slate-800 text-indigo-600 rounded focus:ring-indigo-500 focus:outline-none transition-colors cursor-pointer">
                                <label for="draft" class="text-xs font-mono text-slate-405 select-none cursor-pointer">$ mark_as_draft</label>
                            </div>

                            <!-- Form Actions -->
                            <div class="flex items-center gap-3">
                                <button type="submit" class="px-6 py-2.5 bg-indigo-600 hover:bg-indigo-700 text-white font-mono text-xs font-semibold transition-colors duration-200 cursor-pointer">
                                    $ save_post
                                </button>
                                <a href="/admin/dashboard" class="px-6 py-2.5 bg-slate-900 hover:bg-slate-850 border border-slate-800 text-slate-400 hover:text-slate-350 font-mono text-xs transition-colors duration-200">
                                    cancel
                                </a>
                            </div>
                        </div>
                    </main>
                </div>

                <!-- Right Side: Initial Image Attachment -->
                <div class="space-y-6">
                    <!-- Image Attachment Inputs -->
                    <section class="border border-slate-800 bg-slate-950/60 backdrop-blur-sm p-6 shadow-xl space-y-4">
                        <h2 class="text-md font-mono text-indigo-300">$ attach_initial_image</h2>
                        
                        <!-- File Input -->
                        <div>
                            <label for="file" class="block text-xs font-mono text-slate-500 mb-1.5">$ file_input</label>
                            <input type="file" id="file" name="file" accept="image/*" class="w-full text-xs font-mono text-slate-400 file:mr-4 file:py-2 file:px-4 file:border-0 file:text-xs file:font-semibold file:bg-indigo-600 file:text-white hover:file:bg-indigo-750 file:cursor-pointer border border-slate-800 bg-slate-900 p-2">
                        </div>

                        <!-- Display Title Input -->
                        <div>
                            <label for="img_title" class="block text-xs font-mono text-slate-500 mb-1.5">$ display_title (e.g. fun_clouds.png)</label>
                            <input type="text" id="img_title" name="img_title" placeholder="Optional display name..." class="w-full bg-slate-900 border border-slate-800 p-2 text-xs font-mono text-gray-100 focus:outline-none focus:border-indigo-500 transition-colors">
                        </div>

                        <!-- Tag Input -->
                        <div>
                            <label for="tag" class="block text-xs font-mono text-slate-500 mb-1.5">$ content_tag (e.g. [img1])</label>
                            <input type="text" id="tag" name="tag" placeholder="e.g. [img1]" class="w-full bg-slate-900 border border-slate-800 p-2 text-xs font-mono text-gray-100 focus:outline-none focus:border-indigo-500 transition-colors">
                            <span class="text-[10px] text-slate-500 block mt-1">Place this tag inside the content text to embed the image there.</span>
                        </div>

                        <!-- Description Input -->
                        <div>
                            <label for="description" class="block text-xs font-mono text-slate-500 mb-1.5">$ caption / description</label>
                            <input type="text" id="description" name="description" placeholder="Optional description..." class="w-full bg-slate-900 border border-slate-800 p-2 text-xs text-gray-100 focus:outline-none focus:border-indigo-500 transition-colors">
                        </div>
                    </section>

                    <!-- Associated Media Placeholder -->
                    <section class="border border-slate-800 bg-slate-950/60 backdrop-blur-sm p-6 shadow-xl space-y-4">
                        <h2 class="text-md font-mono text-indigo-300">$ associated_media</h2>
                        <div class="text-xs font-mono text-slate-500 text-center py-6 leading-relaxed space-y-2">
                            <p>No media files uploaded yet.</p>
                            <p class="text-[10px] text-slate-650">You can attach one initial image above. Once the post is published, you can upload additional images here.</p>
                        </div>
                    </section>
                </div>
            </div>
        </form>
    </div>
</body>
</html>
