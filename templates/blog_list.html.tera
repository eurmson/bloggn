<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Blog Posts - {{ title }}</title>
    {% include "tailwind" %}
</head>
<body class="bg-[#020617] text-slate-100 min-h-screen">
    <div class="max-w-4xl mx-auto px-6 py-12 md:py-16">
        <!-- Breadcrumb / Header navigation -->
        <div class="mb-12 flex items-center justify-between">
            <a href="/" class="group flex items-center gap-1.5 text-sm font-mono text-slate-400 hover:text-indigo-400 transition-colors">
                <span class="transform group-hover:-translate-x-0.5 transition-transform">&larr;</span> cd ..
            </a>
            <span class="text-xs font-mono text-slate-500">~/blog</span>
        </div>

        <div class="mb-12">
            <h1 class="text-4xl md:text-5xl font-bold font-heading tracking-tight bg-gradient-to-r from-indigo-200 via-indigo-400 to-purple-300 bg-clip-text text-transparent select-none mb-3">
                All Blog Posts
            </h1>
            <a href="#" id="jump-to-bottom-btn" class="text-slate-400 hover:text-indigo-400 font-mono text-xs transition-colors duration-200 inline-flex items-center gap-1">
                <span>jump_to_newest</span> <span class="text-lg">&darr;</span>
            </a>
        </div>

        {% include "posts_loop" %}
        
        <!-- Bottom Anchor -->
        <div id="bottom"></div>
    </div>
    <script>
        const jumpToBottomBtn = document.getElementById('jump-to-bottom-btn');
        if (jumpToBottomBtn) {
            jumpToBottomBtn.addEventListener('click', (e) => {
                e.preventDefault();
                window.scrollTo({
                    top: document.documentElement.scrollHeight,
                    behavior: 'smooth'
                });
                // Adjust scroll position after lazy-loaded images load/expand
                setTimeout(() => {
                    window.scrollTo({
                        top: document.documentElement.scrollHeight,
                        behavior: 'smooth'
                    });
                }, 300);
            });
        }
    </script>
</body>
</html>