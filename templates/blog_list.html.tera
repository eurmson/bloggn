<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Blog Posts - {{ title }}</title>
    {% include "tailwind" %}
</head>
<body class="bg-[#020617] text-slate-100 min-h-screen">
    <div class="max-w-4xl mx-auto px-6 py-12 md:py-16">
        <!-- Breadcrumb / Header navigation -->
        <div class="mb-12 flex items-center justify-between">
            <a href="/" class="group flex items-center gap-1.5 text-sm font-mono text-slate-400 hover:text-indigo-400 transition-colors">
                <span class="transform group-hover:-translate-x-0.5 transition-transform">&larr;</span> cd ..
            </a>
            <span class="text-xs font-mono text-slate-500">~/blog</span>
        </div>

        <h1 class="text-4xl md:text-5xl font-bold font-heading mb-12 tracking-tight bg-gradient-to-r from-indigo-200 via-indigo-400 to-purple-300 bg-clip-text text-transparent">
            All Blog Posts
        </h1>

        {% include "posts_loop" %}
    </div>
</body>
</html>