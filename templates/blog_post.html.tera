<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ title }} - Blog Post</title>
    {% include "tailwind" %}
</head>
<body class="bg-[#020617] text-slate-100 min-h-screen">
    <div class="max-w-4xl mx-auto px-6 py-12 md:py-16">
        <!-- Breadcrumb / Header navigation -->
        <div class="mb-12 flex items-center justify-between">
            <a href="/blog" class="group flex items-center gap-1.5 text-sm font-mono text-slate-400 hover:text-indigo-400 transition-colors">
                <span class="transform group-hover:-translate-x-0.5 transition-transform">&larr;</span> cd ..
            </a>
            <span class="text-xs font-mono text-slate-500">~/blog/{{ post.id }}</span>
        </div>

        <article class="text-left">
            <!-- Title Bar -->
            <div class="flex flex-col sm:flex-row sm:items-baseline justify-between gap-1 pb-1.5 border-b border-slate-800/80 text-xs font-mono text-slate-500 mb-6">
                <div>
                    <span class="select-none mr-1">$</span>cat {{ post.title | lower | replace(from=": ", to="_") | replace(from=" ", to="_") | replace(from="?", to="") | replace(from="!", to="") | replace(from="'", to="") | replace(from='"', to="") }}.md
                </div>
                <div>
                    — {{ post.published_at | date(format="%Y-%m-%d") }}
                </div>
            </div>

            <!-- Actual Title -->
            <h1 class="text-2xl md:text-4xl font-bold font-heading text-indigo-200 mb-6">
                {{ post.title }}
            </h1>

            <!-- Content Body -->
            <div class="mt-6 text-slate-300 font-light leading-relaxed max-w-3xl whitespace-pre-line">
                {{ content | safe }}
            </div>

            <!-- Bottom Images (Untagged) -->
            {% if images %}
                <div class="mt-8 space-y-6 max-w-3xl">
                    {% for image in images %}
                        <div class="mt-6 mb-1 select-none text-left">
                            <div class="flex items-center gap-1 text-xs font-mono text-slate-500 mb-1.5">
                                <span>$</span>display {{ image.title | default(value=(image.path | split(pat="/") | last)) }}
                            </div>
                            <img src="{{ image.path }}" alt="{{ image.description | default(value='Blog Image') }}" class="block w-full object-cover border-0 p-0 rounded-none" loading="lazy" {% if image.width and image.height %}width="{{ image.width }}" height="{{ image.height }}" style="aspect-ratio: {{ image.width }} / {{ image.height }}; height: auto;"{% endif %}>
                            {% if image.description %}
                                <p class="text-xs font-mono text-slate-500 text-center mt-2">— {{ image.description }}</p>
                            {% endif %}
                        </div>
                    {% endfor %}
                </div>
            {% endif %}
        </article>
    </div>
</body>
</html>